# クライアント（VITE_ 接頭辞あり）。ビルド時にバンドルへ焼き込まれる公開値のみ。
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# サーバー側のみで使用（Vercel Functions）。VITE_ 接頭辞を付けず、
# クライアントバンドルに含めない（漏洩＝不正利用・課金リスクのため）。
# GEMINI_API_KEY: 栄養成分表示の写真解析（api/gemini-nutrition.ts）
# YAHOO_APP_ID:   JANコードから正規の商品名を引く（api/yahoo-jan.ts）
GEMINI_API_KEY=your_gemini_api_key
YAHOO_APP_ID=your_yahoo_developer_client_id
